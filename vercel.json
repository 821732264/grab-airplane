{
  "version": 2,
  "builds": [
    {
      "src": "api/monitor.py",
      "use": "@vercel/python"
    },
    {
      "src": "api/test.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "/api/monitor",
      "dest": "api/monitor.py"
    },
    {
      "src": "/api/test",
      "dest": "api/test.py"
    }
  ],
  "crons": [
    {
      "path": "/api/monitor",
      "schedule": "*/5 * * * *"
    }
  ]
}
